# =============================================
# PRODUCTION ENVIRONMENT - AI Reception API
# Upload this file to your server as: .env
# Fill in all values before uploading
# =============================================

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# API
API_HOST=127.0.0.1
API_PORT=8000
ENVIRONMENT=production

# Claude AI
ANTHROPIC_API_KEY=your_anthropic_api_key_here
MODEL_NAME=claude-haiku-4-5
TEMPERATURE=0.7

# JWT - generate a strong random key for production!
JWT_SECRET_KEY=CHANGE_THIS_TO_A_LONG_RANDOM_STRING_AT_LEAST_32_CHARS
JWT_ALGORITHM=HS256

# Swagger (set to false in production if you want to hide docs)
SWAGGER_ENABLED=true

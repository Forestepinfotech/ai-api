<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>

    <!-- Remove default IIS handlers so Python handles everything -->
    <handlers>
      <remove name="Python27_via_FastCGI" />
      <remove name="Python34_via_FastCGI" />
      <add name="PythonHandler"
           path="*"
           verb="*"
           modules="httpPlatformHandler"
           resourceType="Unspecified"
           requireAccess="Script" />
    </handlers>

    <!-- HttpPlatformHandler: IIS forwards all requests to uvicorn -->
    <httpPlatform processPath="%SystemDrive%\Python310\python.exe"
                  arguments="-m uvicorn main:app --host 127.0.0.1 --port %HTTP_PLATFORM_PORT% --workers 1"
                  stdoutLogEnabled="true"
                  stdoutLogFile=".\logs\uvicorn.log"
                  startupTimeLimit="60"
                  requestTimeout="00:04:00">
      <environmentVariables>
        <environmentVariable name="PORT"        value="%HTTP_PLATFORM_PORT%" />
        <environmentVariable name="ENVIRONMENT" value="production" />
      </environmentVariables>
    </httpPlatform>

    <!-- Allow large request bodies (file uploads etc.) -->
    <security>
      <requestFiltering>
        <requestLimits maxAllowedContentLength="52428800" />
      </requestFiltering>
    </security>

  </system.webServer>
</configuration>
